# Netlify site ID (for CLI deploys and scripts)
NETLIFY_SITE_ID=4858e4f9-5885-4f52-a43d-0a5d3e62470a

# ── Netlify Function env vars (set in Netlify UI or via MCP, not .env) ────────
# These are NOT read locally. They're the expected env vars on the deployed
# Netlify site for the `submit` function to operate:
#
#   TEACHERS_HMAC_SECRET   — shared secret, must match the literal in script.js.
#                            Value is also inlined in browser JS (accepted
#                            tradeoff, same as the main site's lead-intake).
#   TRIGGER_PROD_SECRET_KEY — prod secret for api.trigger.dev, used to auth the
#                            POST to the teacher-intake task.
